// Prisma Schema for MJ First Promoter Platform
// Multi-level referral tracking system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PROMOTER
}

enum UserType {
  ADMIN
  ACCOUNT_MANAGER
  TEAM_MANAGER
  PROMOTER
  CHATTER
  PAYER
}

enum ReferralStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PasswordResetPurpose {
  INVITE
  RESET
}

// API Key model for external integrations
model ApiKey {
  id          String   @id @default(cuid())
  name        String   // Descriptive name (e.g., "TeaseMe Production")
  key         String   @unique // The actual API key
  token       String?  @unique // Bearer token for v2 API
  accountId   String?  // Account ID for v2 API
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relationships
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([key])
  @@index([token])
  @@map("api_keys")
}

// Users table - stores all users regardless of role
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String?  @unique // Unique username for the promoter
  password      String
  firstName     String?
  lastName      String?
  inviteCode    String?  @unique // Unique invite code for promoters (ref_id in FirstPromoter)
  role          UserRole @default(PROMOTER)
  userType      UserType @default(PROMOTER) // Type of user: ADMIN, ACCOUNT_MANAGER, TEAM_MANAGER, or PROMOTER
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Wise payout
  wiseEmail             String?            // Contact / display email (optional)
  wiseRecipientId       String?            // Wise recipient account ID (number stored as string)
  wiseRecipientType     String?            // e.g. "aba", "iban", "email", "australian"

  // Chatter group link for promoters (one promoter → one group)
  chatterGroupId        String?            @unique
  chatterGroup          ChatterGroup?      @relation("PromoterChatterGroup", fields: [chatterGroupId], references: [id], onDelete: SetNull)

  // TeaseMe sync fields
  voiceId               String?
  profilePhotoKey       String?            // S3 key, e.g. "influencers/<username>/profile.jpg"
  profileVideoKey       String?            // S3 key, e.g. "influencers/<username>/video.mp4"
  teasemeSyncedAt       DateTime?

  // Who originally created this user — immutable provenance. Nullable so
  // historical/self-registered users still work. Do NOT mutate this column
  // when reassigning ownership; use `accountManagerId` below for that.
  createdById           String?
  createdBy             User?              @relation("UserCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers          User[]             @relation("UserCreator")

  // The account manager currently responsible for this user. Mutable via
  // PATCH /api/users/:id/account-manager. Distinct from `createdById` so
  // reassignments don't destroy creation provenance. Nullable because admins
  // (and historical rows that predate this column) have no AM. Reads that
  // need to resolve "which AM owns this user?" should use
  // services/ownership.service.ts, which prefers this field and falls back
  // to `createdById` + active referrals for legacy rows.
  accountManagerId      String?
  accountManager        User?              @relation("UserAccountManager", fields: [accountManagerId], references: [id], onDelete: SetNull)
  managedUsers          User[]             @relation("UserAccountManager")

  // Relationships
  createdCampaigns      Campaign[]         @relation("CampaignCreator")
  referralsMade         Referral[]         @relation("ReferrerReferrals")
  referralsReceived     Referral[]         @relation("ReferredUserReferrals")
  commissions           Commission[]
  trackingLinks         TrackingLink[]
  clickTracking         ClickTracking[]
  apiKeys               ApiKey[]
  chatterGroupMemberships ChatterGroupMember[]
  createdChatterGroups  ChatterGroup[]     @relation("ChatterGroupCreator")
  socialLinks           SocialLink[]
  passwordResetTokens   PasswordResetToken[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([inviteCode])
  @@index([createdById])
  @@index([accountManagerId])
  @@map("users")
}

// Short-lived one-time tokens for the password invite / reset flow.
// We only ever store the sha256 of the raw token — the raw value lives
// exclusively in the email we send. `purpose` distinguishes an admin/AM
// invite (first-time password setup) from a self-service forgot-password
// flow so the UI can render the right copy.
model PasswordResetToken {
  id         String               @id @default(cuid())
  userId     String
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String               @unique
  purpose    PasswordResetPurpose @default(INVITE)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime             @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

// Campaign table - promotional campaigns with commission rates
model Campaign {
  id                String   @id @default(cuid())
  name              String
  description       String?
  websiteUrl        String   // The website being promoted
  commissionRate    Float    // Percentage (e.g., 15.0 for 15%)
  secondaryRate     Float?   // Optional: Commission for second-level referrals
  recurringRate     Float?   // Recurring commission for subscriptions
  isActive          Boolean  @default(true)
  startDate         DateTime @default(now())
  endDate           DateTime?
  
  // FirstPromoter-style settings
  cookieLifeDays    Int      @default(60) // Cookie lifetime in days
  autoApprove       Boolean  @default(true) // Auto-approve new promoters
  defaultReferralUrl String? // Default referral link URL
  visibleToPromoters Boolean @default(true) // Whether promoters can see and promote this campaign
  maxInvitesPerMonth Int?    // Max invites per promoter per month (NULL = unlimited)
  linkedCampaignId  String?  // Campaign to assign when inviting from a hidden campaign
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relationships
  createdById       String
  createdBy         User              @relation("CampaignCreator", fields: [createdById], references: [id])
  linkedCampaign    Campaign?         @relation("CampaignLink", fields: [linkedCampaignId], references: [id], onDelete: SetNull)
  linkedBy          Campaign[]        @relation("CampaignLink")
  referrals         Referral[]
  trackingLinks     TrackingLink[]
  commissions       Commission[]
  customers         Customer[]
  transactions      Transaction[]

  @@index([createdById])
  @@index([isActive])
  @@index([linkedCampaignId])
  @@map("campaigns")
}

// Referral table - tracks the referral relationship and hierarchy
model Referral {
  id                String          @id @default(cuid())
  inviteCode        String          @unique // Unique code for this referral
  status            ReferralStatus  @default(PENDING)
  level             Int             @default(1) // 1 = direct, 2 = second-level, etc.
  metadata          Json?           // Store additional tracking data
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  acceptedAt        DateTime?       // When the referred user signed up

  // Relationships
  campaignId        String
  campaign          Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  referrerId        String          // Person who made the referral
  referrer          User            @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referredUserId    String?         // Person who was referred (null until they sign up)
  referredUser      User?           @relation("ReferredUserReferrals", fields: [referredUserId], references: [id])
  parentReferralId  String?         // For multi-level tracking
  parentReferral    Referral?       @relation("ReferralHierarchy", fields: [parentReferralId], references: [id])
  childReferrals    Referral[]      @relation("ReferralHierarchy")
  commissions       Commission[]
  clicks            ClickTracking[]
  customers         Customer[]
  transactions      Transaction[]
  preUser           PreUser?

  @@index([inviteCode])
  @@index([campaignId])
  @@index([referrerId])
  @@index([referredUserId])
  @@index([status])
  @@map("referrals")
}

// PreUser — TeaseMe onboarding state for a referral invite that hasn't yet
// registered in our own system. Seeded alongside Referral in `createReferralInvite`
// and polled against TeaseMe's `user-status` endpoint to track lifecycle
// progress (Step 1 → Step N). Deleted when the invitee hits our `/api/auth/register`
// (they become a real User) or when the parent Referral is hard-deleted
// (ON DELETE CASCADE). Never mutates Referral.status — that transition is
// still owned by the register handler.
model PreUser {
  id            String    @id @default(cuid())
  email         String
  referralId    String?   @unique
  inviteCode    String?   @unique
  teasemeUserId String?
  currentStep   Int       @default(0)
  // Lifecycle status mirrored from TeaseMe's /step-progress response.
  // Values observed so far: "pending". Expected lifecycle on their side is
  // pending -> order_lp -> building -> live. Stored as a free-form string
  // (not an enum) so upstream additions don't require a migration here.
  status        String    @default("pending")
  stepHistory   Json?
  lastCheckedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  referral Referral? @relation(fields: [referralId], references: [id], onDelete: Cascade)

  @@index([email])
  @@map("pre_users")
}

// TrackingLink table - unique URLs for each user/campaign combination
model TrackingLink {
  id            String   @id @default(cuid())
  shortCode     String   @unique // Short code for the URL
  fullUrl       String   // Complete tracking URL
  clicks        Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relationships
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId    String
  campaign      Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  clickTracking ClickTracking[]

  @@index([shortCode])
  @@index([userId])
  @@index([campaignId])
  @@map("tracking_links")
}

// ClickTracking table - tracks individual clicks on tracking links
model ClickTracking {
  id              String   @id @default(cuid())
  ipAddress       String?
  userAgent       String?
  referrerUrl     String?
  metadata        Json?    // Store additional tracking data (location, device, etc.)
  createdAt       DateTime @default(now())

  // Relationships
  trackingLinkId  String
  trackingLink    TrackingLink @relation(fields: [trackingLinkId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?        @relation(fields: [userId], references: [id])
  referralId      String?
  referral        Referral?    @relation(fields: [referralId], references: [id])

  @@index([trackingLinkId])
  @@index([createdAt])
  @@map("click_tracking")
}

// Customer table - tracks actual customers and revenue
model Customer {
  id              String   @id @default(cuid())
  email           String?
  name            String?
  revenue         Float    @default(0) // Total revenue from this customer
  status          String   @default("active") // active, churned, trial
  subscriptionType String? // Subscription plan type
  metadata        String?  // Additional customer data (e.g., event_id)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationships
  campaignId      String
  campaign        Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  referralId      String?
  referral        Referral? @relation(fields: [referralId], references: [id])
  commissions     Commission[]
  transactions    Transaction[]

  @@index([campaignId])
  @@index([referralId])
  @@index([email])
  @@map("customers")
}

// Transaction table - raw sale/refund events
model Transaction {
  id              String   @id @default(cuid())
  eventId         String   @unique // External event_id from payment system
  type            String   @default("sale") // sale, refund
  saleAmount      Float    // Original transaction value (in dollars)
  currency        String   @default("USD")
  status          String   @default("completed") // completed, refunded
  plan            String?
  createdAt       DateTime @default(now())

  // Relationships
  customerId      String?
  customer        Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  campaignId      String?
  campaign        Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  referralId      String?
  referral        Referral?  @relation(fields: [referralId], references: [id])
  originalTransactionId String? // For refunds: points to original sale
  commissions     Commission[]

  @@index([eventId])
  @@index([customerId])
  @@index([campaignId])
  @@map("transactions")
}

// Commission table - tracks earned commissions
model Commission {
  id              String   @id @default(cuid())
  amount          Float    // Commission amount in currency
  percentage      Float    // Percentage used for calculation
  saleAmount      Float?   // Original transaction value this commission was calculated from
  status          String   @default("unpaid") // unpaid, paid, pending
  description     String?
  createdAt       DateTime @default(now())
  paidAt          DateTime?
  wiseTransferId  String?    // Wise transfer ID when paid via Wise
  wiseStatus      String?    // Wise transfer status (e.g. processing, outgoing_payment_sent, funds_converted)

  // Distinguishes promoter commissions from chatter commissions
  type            String   @default("promoter") // "promoter" | "chatter"

  // Relationships
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId      String?
  campaign        Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  referralId      String?
  referral        Referral? @relation(fields: [referralId], references: [id])
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  transactionId   String?
  transaction     Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([campaignId])
  @@index([status])
  @@index([customerId])
  @@index([transactionId])
  @@index([type])
  @@map("commissions")
}

// ChatterGroup — a named group of chatters with a commission percentage
model ChatterGroup {
  id                   String   @id @default(cuid())
  name                 String
  tag                  String?  // Optional short label (e.g. "night-shift", "vip")
  commissionPercentage Float    // Percentage of sale amount paid to chatters in this group
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Account manager who created this group
  createdById          String
  createdBy            User     @relation("ChatterGroupCreator", fields: [createdById], references: [id])

  // Chatters that are members of this group (many-to-many)
  members              ChatterGroupMember[]

  // Promoter linked to this group (one-to-one via User.chatterGroupId)
  promoter             User?    @relation("PromoterChatterGroup")

  @@index([createdById])
  @@map("chatter_groups")
}

// Social links for a user (one-to-many)
model SocialLink {
  id        String   @id @default(cuid())
  platform  String   // "onlyfans", "instagram", "tiktok", "bluesky", ...
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
  @@map("social_links")
}

// Junction table: many-to-many between chatters and chatter groups
model ChatterGroupMember {
  id         String       @id @default(cuid())
  assignedAt DateTime     @default(now())

  chatterId  String
  chatter    User         @relation(fields: [chatterId], references: [id], onDelete: Cascade)
  groupId    String
  group      ChatterGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([chatterId, groupId])
  @@index([chatterId])
  @@index([groupId])
  @@map("chatter_group_members")
}
