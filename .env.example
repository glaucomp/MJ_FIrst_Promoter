PORT=5000
DATABASE_URL=postgresql://username:password@localhost:5432/influencer_platform
JWT_SECRET=your_jwt_secret_key_here_change_in_production
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:5000

# TeaseMe lifecycle lookup — polled by getMyReferrals to render "Step N"
# chips for pending invites. Requires MJFP_TOKEN (same token used by the
# preregister proxy above) for the X-Internal-Token header.
MJFP_TOKEN=your_mjfp_token_here
TEASEME_STATUS_URL=https://tmapi.mxjprod.work/auth/user-status
TEASEME_POLL_TTL_MS=300000